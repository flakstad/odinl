// File-backed development helpers.
//
// This example is for the "I computed/downloaded something once, now I want to
// reuse it in later evals" workflow. There is no hidden REPL state here:
// values are saved to ordinary files, then later eval calls read those files.
(package main)
(import "core:fmt")
(import json "core:encoding/json")
(import os "core:os")

(struct Note {
  :title string
  :body string
})

(struct Count {
  :n int
})

// The examples below write under ./tmp. Odin's write helpers do not create
// parent directories, so production code should create the directory first or
// surface that error. Here we keep the directory policy explicit and boring.
(proc ensure-dev-dir [] -> os.Error
  (let [err (os.make_directory_all "tmp")]
    (if (and (!= err nil)
             (not (os.is_directory "tmp")))
      err
      nil)))

(proc save-note [path: string, text: string] -> os.Error
  (let [dir-err (ensure-dev-dir)]
    (if (!= dir-err nil)
      dir-err
      (spit path text))))

(proc write-as-json [path: string, value: $T] -> [marshal-err: json.Marshal_Error, write-err: os.Error]
  (let [dir-err (ensure-dev-dir)]
    (if (!= dir-err nil)
      (return marshal-err dir-err)
      (let [[data err] (json.marshal value)]
        (if (!= err nil)
          (return err write-err)
          (do
            (defer (delete data))
            (return nil (spit path data))))))))

(proc read-json-as [$T: typeid, path: string] -> [value: T, read-err: os.Error, unmarshal-err: json.Unmarshal_Error]
  (let [[data err] (slurp path)]
    (if (!= err nil)
      (return value err unmarshal-err)
      (do
        (defer (delete data))
        (let [decode-err (json.unmarshal data (& value))]
          (return value nil decode-err))))))

(proc delete-loaded-note [note: Note]
  ;; json.unmarshal allocates string fields with the current allocator. This
  ;; helper is only for Note values loaded from JSON, not Note values built from
  ;; string literals.
  (delete (:title note))
  (delete (:body note)))

(proc print-loaded-note-json [path: string] -> bool
  (let [[note read-err unmarshal-err] (read-json-as Note path)]
    (if (or (!= read-err nil)
            (!= unmarshal-err nil))
      false
      (do
        (defer (delete-loaded-note note))
        (fmt.println note)
        true))))

(proc loaded-note-title-length [path: string] -> int
  (let [[note read-err unmarshal-err] (read-json-as Note path)]
    (if (or (!= read-err nil)
            (!= unmarshal-err nil))
      0
      (do
        (defer (delete-loaded-note note))
        (len (:title note))))))

(proc note-byte-count [path: string] -> int
  (let [[data err] (slurp path)]
    (if (!= err nil)
      0
      (do
        (defer (delete data))
        (len data)))))

(proc load-note [path: string] -> [data: []byte, err: os.Error]
  ;; Ownership of data transfers to the caller.
  (slurp path))

(proc load-count-json [path: string] -> int
  (let [[count read-err unmarshal-err] (read-json-as Count path)]
    (if (or (!= read-err nil)
            (!= unmarshal-err nil))
      0
      (:n count))))

(proc main []
  (return))

(comment
  ;; These forms are meant for editor eval. They deliberately use real files,
  ;; so the result survives across separate odinl eval processes.

  (ensure-dev-dir)
  ;; => nil

  (save-note "tmp/odinl-note.txt" "hello")
  ;; => nil

  ;; JSON is useful for typed cached dev data, but it is not OdinL core syntax.
  ;; write-as-json and read-json-as are ordinary generic procs in this file:
  ;; they call json.marshal and json.unmarshal explicitly, then use spit/slurp
  ;; for file IO. The loaded Note owns its decoded string fields, so the procs
  ;; that use it delete those fields before returning.
  (let [[marshal-err write-err] (write-as-json "tmp/odinl-note.json"
                                               (Note {:title "hello" :body "from OdinL"}))]
    (and (== marshal-err nil)
         (== write-err nil)))
  ;; => true

  (let [[note read-err unmarshal-err] (read-json-as Note "tmp/odinl-note.json")]
    (if (or (!= read-err nil)
            (!= unmarshal-err nil))
      false
      (do
        (defer (delete-loaded-note note))
        (fmt.println note)
        true)))
  ;; prints the parsed Note struct, then returns true

  (print-loaded-note-json "tmp/odinl-note.json")
  ;; => true

  (loaded-note-title-length "tmp/odinl-note.json")
  ;; => 5

  (let [[marshal-err write-err] (write-as-json "tmp/odinl-count.json" (Count {:n 42}))]
    (and (== marshal-err nil)
         (== write-err nil)))
  ;; => true

  (load-count-json "tmp/odinl-count.json")
  ;; => 42

  (note-byte-count "tmp/odinl-note.txt")
  ;; => 5

  (let [[data err] (load-note "tmp/odinl-note.txt")]
    (if (!= err nil)
      0
      (do
        (defer (delete data))
        (len data))))
  ;; => 5
)
